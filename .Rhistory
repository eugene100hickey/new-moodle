library(tidyverse)
uranium <- tribble(~isotope, ~half_life, ~Q, ~series,
"U238", 1.408416e+17, 4.19, "U",
"U236", 7.39079e+14, 4.50, "U",
"U234", 7.747391e+12, 4.77, "U",
"U232", 2174318640, 5.41, "U",
"U230", 1771200, 5.99, "U",
"U228", 546, 6.804, "U",
"Th232", 4.449622e+17, 4.01, "Th",
"Th230", 2.524608e+12, 4.68, "Th",
"Th228", 6027501600, 5.42, "Th",
"Th226", 1836, 6.451, "Th")
uranium |>
ggplot(aes(Q, half_life, group = series)) +
geom_line() +
labs(title = TeX("Log Half-Life versus $\\alpha$ Energy for Some Even-Even Isotopes"),
y = "Isotope Half-Life (s)",
x = "Q (MeV)") +
scale_y_log10(labels = label_log(digits = 2)) +
geom_label(aes(label = isotope), text.colour = "firebrick4", size = 16) +
theme_minimal() +
theme(text = element_text(family = "Ink Free", size = 62),
plot.title = element_text(size = 72, hjust = 1))
